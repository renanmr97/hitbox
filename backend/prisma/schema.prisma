// Schema do banco de dados do projeto Hitbox
// Modelo completo documentado em /docs/database-schema.md

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ====================
// Usuários
// ====================

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")

  reviews   Review[]
  listItems ListItem[]

  // usuários que EU sigo
  following Follow[] @relation("Following")
  // usuários que ME seguem
  followers Follow[] @relation("Followers")

  @@map("users")
}

model Follow {
  id         String @id @default(uuid())
  followerId String @map("follower_id")
  followedId String @map("followed_id")

  follower User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("Followers", fields: [followedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([followerId, followedId])
  @@map("follows")
}

// ====================
// Catálogo de jogos
// ====================

model Game {
  id                  String    @id @default(uuid())
  title               String
  synopsis            String?
  initialReleaseDate  DateTime? @map("initial_release_date")
  igdbUrl             String?   @map("igdb_url")
  wikipediaUrl        String?   @map("wikipedia_url")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  covers           Cover[]
  localizedTitles  LocalizedTitle[]
  gamePlatforms    GamePlatform[]
  gameFranchises   GameFranchise[]
  reviews          Review[]
  listItems        ListItem[]

  @@map("games")
}

model Platform {
  id      String  @id @default(uuid())
  name    String  @unique
  logoUrl String? @map("logo_url")

  gamePlatforms GamePlatform[]

  @@map("platforms")
}

model Franchise {
  id      String  @id @default(uuid())
  name    String  @unique
  logoUrl String? @map("logo_url")

  gameFranchises GameFranchise[]

  @@map("franchises")
}

model GamePlatform {
  id         String @id @default(uuid())
  gameId     String @map("game_id")
  platformId String @map("platform_id")

  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  releases Release[]

  @@unique([gameId, platformId])
  @@map("game_platforms")
}

model GameFranchise {
  id          String @id @default(uuid())
  gameId      String @map("game_id")
  franchiseId String @map("franchise_id")

  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([gameId, franchiseId])
  @@map("game_franchises")
}

model Release {
  id             String   @id @default(uuid())
  gamePlatformId String   @map("game_platform_id")
  region         String
  releaseDate    DateTime @map("release_date")

  gamePlatform GamePlatform @relation(fields: [gamePlatformId], references: [id], onDelete: Cascade)

  @@map("releases")
}

model Cover {
  id        String  @id @default(uuid())
  gameId    String  @map("game_id")
  imageUrl  String  @map("image_url")
  region    String?
  isPrimary Boolean @default(false) @map("is_primary")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("covers")
}

model LocalizedTitle {
  id     String @id @default(uuid())
  gameId String @map("game_id")
  title  String
  locale String

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("localized_titles")
}

// ====================
// Avaliações e listas
// ====================

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("reviews")
}

enum ListStatus {
  WANT_TO_PLAY
  PLAYING
  PLAYED
}

model ListItem {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  gameId    String     @map("game_id")
  status    ListStatus
  isPublic  Boolean    @default(true) @map("is_public")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("list_items")
}